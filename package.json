{
	"name": "rick-and-morty-memory-game",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"author": "Victor Cortés",
	"description": "React application that allows a user to authenticate and play a memory game with characters from Rick and Morty",
	"dependencies": {
		"@supabase/supabase-js": "2.98.0",
		"@tailwindcss/vite": "4.2.1",
		"@tanstack/react-query": "5.90.21",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-router": "7.13.1",
		"tailwindcss": "4.2.1",
		"zustand": "5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@commitlint/cli": "20.4.2",
		"@commitlint/config-conventional": "20.4.2",
		"@types/node": "24.11.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react-swc": "4.2.3",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"typescript": "5.9.3",
		"vite": "7.3.1"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.30.3",
	"lint-staged": {
		"*.{js,jsx,ts,tsx,cjs,mjs,json}": [
			"biome check --write",
			"biome format --write"
		]
	}
}
